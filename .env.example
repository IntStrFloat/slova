# ── Backend (см. docs/specs/11,14) ───────────────────────────────────────────
# Изолированный backend Slova на общем сервере (НЕ bloxx): порт 8788, сабдомен slova.*
EXPO_PUBLIC_API_URL=https://slova.193.160.208.95.nip.io

# ── Реклама Yandex Mobile Ads (см. docs/specs/05) ─────────────────────────────
# Production ad-unit IDs из кабинета Яндекса. Без значений используются demo-юниты.
EXPO_PUBLIC_YANDEX_BANNER_AD_UNIT_ID=
EXPO_PUBLIC_YANDEX_INTERSTITIAL_AD_UNIT_ID=
EXPO_PUBLIC_YANDEX_REWARDED_AD_UNIT_ID=
# UAuth-токен кабинета Яндекса — НЕ EXPO_PUBLIC (в APK не попадает), только локально:
YANDEX_ADS_UAUTH_TOKEN=

# ── RuStore (см. docs/specs/05,11,12) ─────────────────────────────────────────
# Публичный projectId пушей RuStore (не секрет). Сервисный токен — только в консоли RuStore.
EXPO_PUBLIC_RUSTORE_PUSH_PROJECT_ID=
# consoleApplicationId для RuStore Billing (после регистрации приложения в RuStore Console)
EXPO_PUBLIC_RUSTORE_CONSOLE_APP_ID=

# ── Аналитика AppMetrica (см. docs/specs/16) ──────────────────────────────────
# UUID-ключ AppMetrica. Включается в prebuild только если задан валидный UUID.
APPMETRICA_API_KEY=
