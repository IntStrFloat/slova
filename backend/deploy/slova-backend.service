[Unit]
Description=Slova leaderboard backend
After=network.target

[Service]
Type=simple
User=slova
Group=slova
WorkingDirectory=/opt/slova/backend
EnvironmentFile=/opt/slova/backend.env
ExecStart=/usr/bin/node /opt/slova/backend/index.cjs
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/slova

[Install]
WantedBy=multi-user.target
